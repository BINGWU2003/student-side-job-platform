# pnpm 配置文件

# 自动安装 peer dependencies（避免手动安装对等依赖）
auto-install-peers=true

# ====================
# 性能优化
# ====================

# 启用锁文件（确保依赖版本一致性）
lockfile=true

# ====================
# 包管理配置
# ====================

# 引擎检查（确保 Node.js 版本符合要求）
engine-strict=true

# ====================
# 发布配置
# ====================

# 禁止发布到公共 npm（如果是私有项目）
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# 允许运行构建脚本的包
# approve-builds=esbuild,vue-demi,prisma,@prisma/client,@prisma/engines,@parcel/watcher
