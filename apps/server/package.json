{
  "name": "@bingwu-my-monorepo/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "dev:test": "cross-env NODE_ENV=test nodemon",
    "build": "prisma generate && tsup",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:test": "cross-env NODE_ENV=test node dist/index.js",
    "deploy": "prisma migrate deploy && node dist/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:test": "pm2 start ecosystem.config.cjs --only server-test",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs server",
    "pm2:status": "pm2 status",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e env/.env.development -- prisma db push",
    "db:push:test": "dotenv -e env/.env.test -- prisma db push",
    "db:migrate": "dotenv -e env/.env.development -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e env/.env.production -- prisma migrate deploy",
    "db:studio": "dotenv -e env/.env.development -- prisma studio",
    "db:reset": "dotenv -e env/.env.development -- prisma migrate reset",
    "clean": "rimraf node_modules dist"
  },
  "dependencies": {
    "@bingwu-my-monorepo/shared": "workspace:*",
    "@bingwu-my-monorepo/shared-schemas": "workspace:*",
    "@bingwu-my-monorepo/shared-types": "workspace:*",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.10.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  }
}
