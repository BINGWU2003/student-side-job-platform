    "preview": "vite preview --port 3001",
    "clean": "rimraf node_modules dist"
  },
  "dependencies": {
    "vue": "^3.5.24",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "@bingwu-my-monorepo/shared": "workspace:*",
    "@bingwu-my-monorepo/components": "workspace:*",
    "@bingwu-my-monorepo/shared-types": "workspace:*",
    "@bingwu-my-monorepo/shared-schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "sass-embedded": "^1.93.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vue-tsc": "^3.1.3"
  }
}
