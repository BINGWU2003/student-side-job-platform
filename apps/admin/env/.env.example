# 管理后台环境变量说明
# 复制对应文件并按需修改：
#   .env.development  → 开发环境（pnpm dev 自动加载）
#   .env.test         → 测试环境（pnpm build:test 加载）
#   .env.production   → 生产环境（pnpm build 加载）
#
# 如需覆盖本机配置，新建 .env.development.local（已被 .gitignore 忽略）

# API 服务地址
VITE_API_BASE_URL=http://localhost:4000

# 应用标题
VITE_APP_TITLE=Admin Console

# 当前环境标识（development | test | production）
VITE_ENV=development
